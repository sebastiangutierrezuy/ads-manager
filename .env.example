# ─────────────────────────────────────────────────────────────
# Meta Marketing API — credenciales
# Copiar este archivo a .env.local y completar.
# .env.local NUNCA se commitea (está en .gitignore).
# ─────────────────────────────────────────────────────────────

# Token de acceso a la Marketing API (long-lived o System User).
# Cómo obtenerlo: ver README.md
META_ACCESS_TOKEN=

# ID de la cuenta publicitaria (con prefijo act_).
# Lo encontrás en Meta Ads Manager > arriba a la izquierda, debajo del nombre de la cuenta.
# Ejemplo: act_123456789012345
META_AD_ACCOUNT_ID=

# App ID y App Secret de tu Meta App.
# Solo necesarios si vas a refrescar tokens automáticamente. Para arrancar
# alcanza con META_ACCESS_TOKEN.
META_APP_ID=
META_APP_SECRET=

# Versión de la Graph API (opcional, default v21.0)
META_API_VERSION=v21.0

# ─────────────────────────────────────────────────────────────
# Auth.js (Google Workspace SSO)
# Cómo obtenerlas: ver README.md → "Configurar autenticación"
# ─────────────────────────────────────────────────────────────

# String aleatorio para firmar sesiones. Generar con:
#   openssl rand -base64 32
AUTH_SECRET=

# URL base de la app. En dev podés dejar vacío (NextAuth detecta localhost:3000).
# En producción es OBLIGATORIO ponerlo (ej. https://ads.atlanticoestudio.com).
NEXTAUTH_URL=

# Credenciales OAuth de Google Cloud
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Dominio de Google Workspace permitido (ej. atlanticoestudio.com).
# Solo usuarios con email de este dominio pueden iniciar sesión.
# Dejar vacío para permitir cualquier cuenta de Google (no recomendado).
AUTH_ALLOWED_DOMAIN=

# Whitelist explícita de emails (separados por coma). Si está seteada,
# TIENE PRIORIDAD sobre AUTH_ALLOWED_DOMAIN — solo estos emails entran.
# Útil cuando querés restringir aún más dentro del Workspace.
# Ejemplo: AUTH_ALLOWED_EMAILS=alguien@example.com,otro@example.com
AUTH_ALLOWED_EMAILS=
